# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# --- Lifehut Studio Config ---
# Admin Authentication credentials
ADMIN_EMAIL="admin@lifehutsolutions.com"
ADMIN_PASSWORD="Lifehut@2026"

# GitHub Token and Repository for file storage & Gist DB integration
# Create a GitHub PAT with 'gist' and 'repo' scopes
GITHUB_TOKEN=""
# Format: "owner/repo" for releases, e.g. "lifehutsolutions/themes"
GITHUB_REPO=""
# Optional: private Gist ID to store the products.json database.
# If not provided, a private Gist is automatically created or a local file is used.
GITHUB_GIST_ID=""

# Razorpay credentials for payment processing
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
